// agentguard starter schema for AI agents.
//
// Conventions:
//   * Principal types: User (humans) and Agent (AI agents)
//   * Resource types: defined by your domain (Mailbox, Repo, Doc, ...)
//   * Actions: Action::"ToolCall::<tool_name>" and optionally "::<operation>"
//
// Every action's context has the same shape:
//   - tool-specific args flattened to top level (so they can be type-checked)
//   - `session`: { ip, user_agent, mfa, ts } — populated by the SDK
//
// This file is loaded by `agentguard init` and lives at
// .agentguard/schema.cedarschema.

type Session = {
  ip?: String,
  user_agent?: String,
  mfa?: Bool,
  ts?: Long,
};

entity User;

entity Agent {
  parent?: Agent,
  registered_tools?: String,
};

entity Mailbox { owner: User };
entity Document { owner: User, visibility: String };
entity Repository { org: String };

action "ToolCall::send_email" appliesTo {
  principal: [User, Agent],
  resource: [Mailbox],
  context: { to: String, subject: String, body: String, session: Session }
};

action "ToolCall::read_doc" appliesTo {
  principal: [User, Agent],
  resource: [Document],
  context: { doc_id: String, session: Session }
};

action "ToolCall::write_doc" appliesTo {
  principal: [User, Agent],
  resource: [Document],
  context: { doc_id: String, body: String, session: Session }
};

action "ToolCall::repo_read" appliesTo {
  principal: [User, Agent],
  resource: [Repository],
  context: { repo: String, session: Session }
};

action "ToolCall::repo_write" appliesTo {
  principal: [User, Agent],
  resource: [Repository],
  context: { repo: String, branch: String, session: Session }
};

action "ToolCall::shell_exec" appliesTo {
  principal: [Agent],
  resource: [Repository],
  context: { cmd: String, session: Session }
};

action "ToolCall::web_fetch" appliesTo {
  principal: [User, Agent],
  resource: [Document],
  context: { url: String, session: Session }
};